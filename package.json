{
  "name": "contribute_opensource",
  "version": "1.0.0",
  "description": "> **Spring Boot 오픈소스 기여 활동 기록**   > 백엔드 개발자 취업을 위한 포트폴리오 프로젝트",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint:md": "find . -name '*.md' -not -path './node_modules/*' -not -path './portfolio/*' -not -path './02-spring-projects/*' -print0 | xargs -0 ./node_modules/.bin/markdownlint --config .markdownlint.json",
    "lint:links": "find . -name '*.md' -not -path './node_modules/*' -not -path './portfolio/*' -not -path './02-spring-projects/*' -print0 | xargs -0 ./node_modules/.bin/markdown-link-check --config .markdown-link-check.json",
    "lint:links:all": "find . -name '*.md' -not -path './node_modules/*' -not -path './portfolio/*' -not -path './02-spring-projects/*' -print0 | xargs -0 ./node_modules/.bin/markdown-link-check",
    "format": "find . -name '*.md' -not -path './node_modules/*' -not -path './portfolio/*' -not -path './02-spring-projects/*' -print0 | xargs -0 ./node_modules/.bin/prettier --write",
    "validate": "npm run lint:md && npm run lint:links",
    "validate:full": "npm run lint:md && npm run lint:links:all"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli": "^0.47.0",
    "prettier": "^3.8.1"
  }
}
